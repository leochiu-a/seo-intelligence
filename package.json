{
  "name": "seo-intelligence",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19",
      "@types/react-dom": "^19"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @seo-intelligence/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "preview": "pnpm --filter @seo-intelligence/web preview",
    "type-check": "pnpm -r type-check",
    "prepare": "husky",
    "docs:dev": "pnpm --filter @seo-intelligence/docs dev"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  }
}
